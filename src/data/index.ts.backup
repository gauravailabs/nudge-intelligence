export const NEWS_INTERNAL = [
  { id:'ni1', title:'Freyr Named Leader Again in Everest Group Regulatory & Medical Affairs PEAK Matrix® 2026', date:'May 2026', featured:true,
    body:'Freyr retained its Leader position in the Everest Group Life Sciences Regulatory and Medical Affairs Operations PEAK Matrix® Assessment 2026 — its third consecutive year at the top of the matrix. Everest Group analysts cited Freyr\'s expanded affiliate network (now 850+ EU in-country experts, 120+ countries), the maturity of the AI-first freya fusion platform, and proven multi-agency eCTD v4.0 delivery. Freyr now supports 1,600+ customers worldwide with 2,500+ regulatory experts. The recognition reinforces Freyr as the partner of choice for regulated life sciences companies pursuing AI-driven regulatory operations at scale.' },
  { id:'ni2', title:'freya fusion 2.0 Released — GenAI Dossier Authoring and Multi-LLM Orchestration Go GA', date:'Apr 2026',
    body:'Freyr announced general availability of freya fusion 2.0, adding a production-grade GenAI dossier authoring module targeting 50%+ compilation-time reduction, multi-LLM orchestration with domain-specific GxP guardrails, and native eCTD v4.0 publishing through SUBMIT PRO. Built on 15+ years of regulatory delivery data, freya fusion 2.0 is ISO 27001/27701 certified with full audit trails and human-in-the-loop validation by design. The release directly answers the industry shift toward auditable, enterprise-scale regulatory AI that regulated knowledge-work demands.' },
  { id:'ni3', title:'Freyr Expands Japan Operations Ahead of PMDA eCTD v4.0 Mandate', date:'Mar 2026',
    body:'With PMDA Japan the first agency globally to mandate eCTD v4.0 (effective 2026), Freyr expanded its Tokyo regulatory operations centre and is now supporting multiple sponsors through their first v4.0 submissions. The expansion strengthens Freyr\'s position for Japan-headquartered clients executing simultaneous US/EU/Japan filings, and complements the December 2025 start of EMA optional v4.0 acceptance ahead of the planned 2027 EU mandate.' },
  { id:'ni4', title:'Freyr Launches freya.intelligence Real-Time Regulatory Monitoring — 95,000+ Regulations, 200+ Markets', date:'Feb 2026',
    body:'Freyr scaled freya.intelligence, its regulatory intelligence SaaS, to track 95,000+ regulations across 200+ markets with BOT-driven real-time monitoring, Freya.KnowledgeGraphs for cross-country comparison, and an AI chatbot in 60+ languages. Positioned as an auditable, cost-efficient substitute for in-house monitoring headcount, the platform is being adopted by sponsors under cost-reduction mandates who need always-on compliance coverage without expanding FTEs.' },
  { id:'ni5', title:'Freyr Featured in CIO Bulletin — 2026 Strategic Growth and Global Footprint', date:'Jan 2026',
    body:'Freyr Solutions was featured in CIO Bulletin as one of the most strategically significant regulatory technology companies of 2026, highlighting expansion across 20+ global locations and a deepening footprint in the US, EU, Japan, India, Brazil, and Southeast Asia. The feature called out freya fusion as a key differentiator in an increasingly competitive regulatory technology landscape and noted Freyr\'s single-partner accountability model across regulatory affairs, pharmacovigilance, medical writing, submissions, and artwork operations.' },
  { id:'ni6', title:'Freyr Wins Multi-Service Regulatory Mandate with Global Top-20 Pharma', date:'Jan 2026',
    body:'Freyr was awarded a multi-year, multi-service regulatory mandate with a global top-20 pharmaceutical company spanning Core Services (Regulatory Operations, eCTD publishing, LABEL 360), Growth Services (pharmacovigilance and MLR), and Technology (freya.intelligence + VIA). The win validates Freyr\'s Full-Service "Land–Expand–Transform" model as large pharma consolidate fragmented vendor rosters toward single strategic partners with end-to-end capability — exactly the vendor-rationalisation pressure shaping restructuring programmes across the industry.' },
]

export const NEWS_EXTERNAL_REVANCE = [
  { id:'er1', title:'Crown Laboratories Completes Revance Executive Reset — Vendor Review Slated for H2 2026', date:'Jan 2026',
    body:'Following the $924M acquisition (completed Feb 2025), Crown Laboratories has fully bedded in its new Revance leadership — CEO Nadeem Moiz, COO Nick Crowe, and CFO Scott Leffler, all installed October 2025 as a coordinated Crown integration troika. As integration stabilises in 2026, Crown is preparing a full review of all inherited Revance vendor contracts in H2 2026, evaluated against PE-portfolio criteria: measurable ROI, short payback, and contract flexibility. CLO Kira Schwartz holds regulatory-compliance oversight in the governance model, making her a non-obvious but decisive vendor approver.' },
  { id:'er2', title:'DAXXIFY EU Regulatory Gap Reaches Year Four — Lost EU Revenue Estimated $320M+', date:'May 2026',
    body:'DAXXIFY entered its fourth year without EU market authorisation, with analysts estimating cumulative lost EU aesthetics revenue at $320M+ since FDA approval in September 2022. The EU aesthetics injectable market — projected at $1.8B by 2027 — remains dominated by Allergan\'s BOTOX and Ipsen\'s Dysport. No EMA Centralised Procedure application for DAXXIFY has been publicly filed, leaving the largest addressable revenue opportunity in Crown\'s Revance investment uncontested by any incumbent regulatory partner.' },
  { id:'er3', title:'DAXXIFY Multi-Indication Pipeline Advances — Phase II Spasticity & Plantar Fasciitis, Fosun China Active', date:'Apr 2026',
    body:'Revance\'s DAXXIFY programme continues to advance therapeutically, with Phase II trials active for upper limb spasticity and plantar fasciitis, and NMPA China development progressing through the Fosun Pharma partnership. Three simultaneous regulatory pathways (US, EU prep, China) are compounding CMC variation-management workload. DAXXIFY\'s peptide-exchange technology — enabling up to six-month duration — is especially compelling in spasticity, where treatment frequency is a patient burden.' },
  { id:'er4', title:'EMA Begins Optional eCTD v4.0 Acceptance — 2027 Mandate Looms for EU Filings', date:'Feb 2026',
    body:'EMA began accepting optional Centralised Procedure submissions in eCTD v4.0 from December 22, 2025, with a 2027 mandate planned. Combined with PMDA Japan\'s 2026 mandate and FDA acceptance since September 2024, sponsors face a multi-agency v4.0 transition. For Revance, a DAXXIFY EMA programme initiated now would land squarely in the v4.0 window — making SUBMIT PRO\'s native v4.0 publishing and validation a material readiness advantage.' },
  { id:'er5', title:'Cervical Dystonia PV Obligations Intensify in DAXXIFY Second Commercial Year', date:'Mar 2026',
    body:'DAXXIFY cervical dystonia, commercially launched May 2024, is now in its second full year of mandatory pharmacovigilance. Botulinum toxin therapeutics carry well-characterised adverse-event complexity (dysphagia, systemic spread), driving ongoing ICSR processing, PSUR/PBRER authoring, signal detection, and REMS compliance under FDA 21 CFR 314 — an active obligation with no confirmed Freyr engagement and a fast, adjacent cross-sell entry point.' },
]

export const NEWS_EXTERNAL_TAKEDA = [
  { id:'et1', title:'Julie Kim Becomes Takeda President & CEO — First Woman, First American, First Korean-American', date:'Jun 2026',
    body:'Julie Kim assumed the President & CEO role at Takeda effective June 24, 2026, succeeding Christophe Weber after ~12 years. The first female, first American, and first Korean-American to lead Takeda in approximately 250 years, Kim had operated with CEO authority for months to avoid a lame-duck transition. She is expected to immediately commence a 100-day strategic review that will set the FY2027 technology and vendor agenda — a narrow window for partners to be named on the shortlist.' },
  { id:'et2', title:'Takeda Transformation Office Builds FY2027 AI Investment Portfolio Under CTO Lauren Duprey', date:'May 2026',
    body:'Takeda\'s newly established Transformation Office, led by Chief Transformation Officer Lauren Duprey (effective April 2026), is assembling the FY2027 enterprise AI investment portfolio now. The mandate: connect AI transformation enterprise-wide, prove auditable AI ROI at scale, and reduce headcount dependency — contributing to the JPY 200B+ annualised gross savings target by FY2028. Duprey, formerly CHRO, frames the agenda around workforce redesign rather than platform features, treating AI agents as part of the workforce.' },
  { id:'et3', title:'Oveporexton FDA Review On Track for H2 2026 Launch — Narcolepsy Type 1', date:'May 2026',
    body:'Takeda\'s oveporexton (TAK-861), an orexin receptor 2 agonist for narcolepsy type 1, is tracking for FDA approval and H2 2026 launch, holding Breakthrough Therapy and Fast Track designations. Concurrent US, Japan, and China filings demand significant regulatory operations capacity — at the same time the 4,500-person restructuring constrains in-house headcount, creating an urgent surge-capacity requirement.' },
  { id:'et4', title:'Rusfertide and Zasocitinib Round Out Takeda\'s Heaviest Launch Programme in Years', date:'Apr 2026',
    body:'Alongside oveporexton, rusfertide (hepcidin mimetic for polycythemia vera, FDA Priority Review) targets an H2 2026 launch and zasocitinib (TYK2 inhibitor for psoriasis, EU/US preparation) an H1 2027 launch. Three simultaneous NDA/MAA streams across the Americas, Europe, and ROW generate concurrent regulatory operations, labeling, REMS, and pharmacovigilance workload — the largest simultaneous filing programme Takeda has run since the 2019 Shire acquisition.' },
  { id:'et5', title:'Takeda Names Director of Launch Excellence; Tightens Procurement via SAP Ariba', date:'Mar 2026',
    body:'Takeda is standing up a Director of Launch Excellence role and launch control towers to govern its late-stage pipeline, while centralising procurement and vendor governance through SAP Ariba integration amid the restructuring. The moves increase demand for vendor compliance, fast-track assessments, and benefits-tracking — and signal that vendor decisions will run through a tighter, more governed procurement function during FY2026–FY2027.' },
  { id:'et6', title:'Takeda Accelerates Cloud Migration — 96% of Data Targeted for Cloud, 40% Productivity Goal', date:'Feb 2026',
    body:'Takeda\'s DD&T organisation under CDTO Gabriele Ricci is migrating ~96% of enterprise data to cloud platforms, targeting a 40% increase in data productivity, with GenAI tools deployed to 24,000+ employees across Innovation Capability Centers in India, Mexico, Slovakia, and Japan. The programme requires AI-ready data platforms with strong governance and quality controls — and a multi-model orchestration philosophy that favours regulatory-native, GxP-compliant AI over generic enterprise tooling.' },
]

