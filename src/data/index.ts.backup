    orgLeadership:[
      { role:'CEO (Crown placement)', name:'Nadeem Moiz', relationship:'cold',
        insight:'PRIORITY. No legacy relationship. Entry via Head of RA then Schwartz, then Moiz.',
        dos:['Lead with EU commercial gap: DAXXIFY 3+ years FDA-approved with zero EU revenue','Frame Freyr as vendor consolidation — one partner for all regulatory operations','Use PE language: ROI, payback period, FTE reduction'],
        donts:['Do not use innovation or partnership language','Do not cold approach — require warm introduction from regulatory layer first'],
        conference:'Crown Laboratories Portfolio Reviews (internal)',
        sellingPoint:'Freyr is the only regulatory partner with 850+ EU in-country affiliates and purpose-built EU regulatory intelligence for DAXXIFY EMA authorisation.' },
      { role:'Chief Legal Officer', name:'Kira Schwartz', relationship:'cold',
        insight:'PRIORITY. Regulatory compliance gatekeeper. Co-approver on all vendor decisions.',
        dos:['Lead with compliance and audit-readiness: freya fusion GxP-compliant architecture','Present freya fusion audit trail completeness and ISO 27001/27701 certification'],
        donts:['Do not lead with regulatory science or submission workflow','Avoid speculative language about platform capabilities'],
        conference:'Pharma Legal & Compliance Forums',
        sellingPoint:'Freyr freya fusion platform is GxP-compliant by design with full audit trails — directly addressing compliance risk reduction mandate.' },
      { role:'Chief Operating Officer', name:'Nick Crowe', relationship:'cold',
        insight:'Operational validator. Vendor rationalisation mandate — will map all inherited contracts.',
        dos:['Lead with vendor consolidation savings model: one partner vs four separate contracts','Present operational efficiency metrics and FTE reduction through automation'],
        donts:['Do not lead with regulatory science','Do not present without a cost reduction attached'],
        sellingPoint:'Freyr Full-Service Model reduces vendor fragmentation — one partner across regulatory, PV, labeling, and technology.' },
      { role:'Chief Financial Officer', name:'Scott Leffler', relationship:'cold',
        insight:'Budget authority above delegated threshold. ROI model required before first meeting.',
        dos:['Open with EU programme cost vs revenue unlock: DAXXIFY EU authorisation NPV model','Frame investment as Crown investment thesis performance — DAXXIFY financial return'],
        donts:['Do not present without the ROI model','Do not lead with regulatory science or technology features'],
        conference:'BioPharma Finance & PE Summit 2026',
        sellingPoint:'The EU approval revenue opportunity is the largest financial lever. Freyr EU programme cost is a fraction of the EU aesthetics revenue DAXXIFY can access.' },
      { role:'Chief Innovation Officer', name:'Thomas Hitchcock, PhD', relationship:'cold',
        insight:'Technology track sponsor for VIA and freya.intelligence. PhD scientist — credibility matters.',
        dos:['Lead with multi-indication regulatory complexity: how is the team managing variation management across three regulatory pathways?','Frame VIA as the tool that makes regulatory complexity manageable at scale'],
        donts:['Do not position Freyr as a pure operational vendor','Do not overstate AI automation without discussing human scientific oversight'],
        conference:'DIA Annual Meeting 2026; ISTH Congress 2026',
