    playAreas:{
      nudgeSignal:"Current Freyr engagement at Revance is a single service line (country expansion regulatory services) in a single geography (Americas primary). The account is significantly underpenetrated relative to its revenue potential and the number of active Freyr-relevant programmes running right now. Three Growth Services lines (PV, MLR, Medical Affairs) are entirely absent. All three have live, active demand drivers.",
      whatThisMeansForFreyr:'Technology entry is the path to making Revance a structurally sticky account. freya.intelligence POC for EU regulatory monitoring is the natural, low-friction start — it directly supports the DAXXIFY EU programme that is already a scoping conversation.',
      coreServices:[
        { service:'EU/EMA Regulatory Operations', opportunity:'DAXXIFY EU authorisation programme — glabellar lines and cervical dystonia EMA dossier. Freyr EU affiliate network (850+), EMA biologics submission precedent, freya.intelligence EU pathway analysis. Multi-year programme.', revenue:'$2.5M FY27', priority:'MOST URGENT' },
        { service:'Regulatory Operations — US (expand)', opportunity:'Extend existing country expansion RA services to include SUBMIT PRO eCTD publishing, rDMS document management, and REMS compliance support for both DAXXIFY indications.', revenue:'$0.8M FY27', priority:'ACTIVE — EXPAND' },
        { service:'Labeling & Artwork — LABEL 360', opportunity:'Two separate DAXXIFY US labels (aesthetics + cervical dystonia), REMS labeling, SPL structured labeling, EU label preparation ahead of EMA authorisation. Ongoing lifecycle management.', revenue:'$0.5M FY27', priority:'HIGH' },
        { service:'China NMPA Regulatory (Fosun)', opportunity:'DAXXIFY NMPA submissions via Fosun partnership. Country-specific regulatory strategy and variation management. Freyr China affiliates + VIA. Entry: CMC Director.', revenue:'$0.6M FY27', priority:'HIGH' },
        { service:'Regulatory Strategy — Multi-Indication', opportunity:'DAXXIFY Phase II (upper limb spasticity, plantar fasciitis) IND/NDA regulatory strategy. Independent indication pathways from aesthetics/cervical dystonia. Entry via Hitchcock (CInO). Q4 2026.', revenue:'$0.5M FY27', priority:'MEDIUM' },
        { service:'Regulatory Intelligence Services', opportunity:'freya.intelligence upgrade path from existing RA relationship. EMA pathway analysis, BOTOX/Dysport EU comparator monitoring, NMPA guidance tracking for Fosun programme. 60-day POC Q3 2026.', revenue:'$0.3M ARR', priority:'MEDIUM' },
