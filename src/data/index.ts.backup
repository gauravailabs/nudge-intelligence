      growthServices:[
        { service:'Pharmacovigilance (PV)', opportunity:'Active cervical dystonia commercial PV programme since May 2024. Botulinum toxin AE complexity (dysphagia, systemic spread). ICSR, PSUR/PBRER, signal detection, REMS. No confirmed incumbent. Entry: single question to Head of RA. Fastest revenue entry in the account.', revenue:'$1.5M FY27', priority:'MOST URGENT' },
        { service:'MLR Review', opportunity:'DAXXIFY aesthetics branded promotional campaigns under FDA 21 CFR 202. Active HCP and DTC marketing. Freyr MLR: 120+ countries, round-the-clock medical/legal/regulatory review. Entry: Medical Affairs or Commercial contact.', revenue:'$0.8M FY27', priority:'HIGH' },
        { service:'Medical Affairs', opportunity:'DAXXIFY cervical dystonia KOL engagement, scientific content development, medical communications for therapeutics indication. Entry: Head of Medical Affairs. Q4 2026.', revenue:'$0.5M FY27', priority:'MEDIUM' },
        { service:'Clinical Consulting', opportunity:'Phase II pipeline (spasticity, plantar fasciitis) clinical regulatory strategy. IND/NDA planning 12-18 months ahead of filing. Build into FY2027.', revenue:'$0.3M FY27', priority:'FY2027' },
      ],
      technologyTrack:[
        { platform:'freya.intelligence (Reg Intelligence SaaS)', entryPath:'EU programme entry creates natural POC hook. 60-day POC scoped to EMA pathway analysis for DAXXIFY, BOTOX/Dysport EU comparator monitoring, NMPA guidance tracking. Approved at regulatory team level — does not require Crown CEO approval. Convert to SaaS subscription pre-year-end.', revenue:'$0.3M ARR', stage:'NEAR-TERM' },
        { platform:'VIA — Variation Identification Agent', entryPath:'Fosun China NMPA variation management is the specific entry trigger. DAXXIFY multi-indication expansion (spasticity, plantar fasciitis) will compound variation workload globally. Pitch to Hitchcock and CMC Director: variation cycle time reduction, cost per filing. PE-compatible ROI metric.', revenue:'$0.4M ARR', stage:'Q4 2026' },
        { platform:'SUBMIT PRO + freya.docs', entryPath:'Low-friction extension of existing Freyr-managed regulatory operations. Revance-side SUBMIT PRO deployment for DAXXIFY NDA/supplement eCTD publishing. Demo to Reg Ops Q3 2026.', revenue:'$0.2M ARR', stage:'NEAR-TERM' },
        { platform:'freya fusion (AI-First RIM Cloud)', entryPath:"Not a 2026 conversation. Crown PE governance requires demonstrated ROI from smaller Freyr investments first. Path: freya.intelligence SaaS + PV service → EU programme delivery → freya fusion enterprise pitch in FY2027-2028.", revenue:'$1.0M ARR', stage:'FY2027-2028' },
