    financialSnapshot:[
      { label:'Current Freyr Revenue', value:'<$0.5M / year' },
      { label:'3-Year Target (Base)', value:'$12–16M cumulative' },
      { label:'FY2026 H2 Target', value:'$1.1M' },
      { label:'FY2027 Target', value:'$6.0M' },
